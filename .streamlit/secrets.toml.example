# Copia este archivo a .streamlit/secrets.toml y completa con tus valores.
# El archivo secrets.toml NO se subira al repo (esta en .gitignore).
#
# Para deploy en Streamlit Community Cloud: pegar el contenido en
# "Settings -> Secrets" desde la app de Streamlit Cloud.

# -----------------------------------------------------------------------------
# Persistencia (Postgres via Supabase recomendado)
# -----------------------------------------------------------------------------
# Si NO definis esta variable, la app cae automaticamente a SQLite local
# (data/portfolio.db). Eso anda bien para desarrollo, pero en Streamlit Cloud
# el filesystem es efimero y se borra en cada redeploy: vas a perder
# todos los clientes.
#
# Para usar Supabase (gratis hasta 500MB):
#  1. Crea un proyecto en https://supabase.com
#  2. Project Settings -> Database -> Connection string -> URI
#     (usa "Session mode" puerto 5432, NO el de transaction mode 6543)
#  3. Reemplaza [YOUR-PASSWORD] por la password del proyecto
#  4. Pega el string aca abajo
#
DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# API key de Google Gemini (https://aistudio.google.com/apikey)
# -----------------------------------------------------------------------------
GEMINI_API_KEY = "AIza..."
